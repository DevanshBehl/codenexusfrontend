# CodeNexus Frontend Environment Variables
# Copy this file to .env and configure as needed

# Set to 'true' to enable mock API mode (no backend server required)
# Use test accounts: student@test.dev, university@test.dev, company@test.dev, recruiter@test.dev
# Password for all: password123
VITE_MOCK_API=false

# API URL (used for recording streams and direct API calls)
# Defaults to proxy if not set
# VITE_API_URL=http://localhost:8000
